{
  "id": "fleet-command",
  "name": "Fleet Command Center",
  "version": "2.0.0",
  "description": "AI-powered fleet management with real-time vehicle tracking, route optimization, and driver safety scoring.",
  "orchestrator_skill": "vehicle-tracker",
  "identity": {
    "actor_types": [
      {
        "key": "fleet_manager",
        "label": "Fleet Manager",
        "description": "Fleet operations manager with full access"
      },
      {
        "key": "dispatcher",
        "label": "Dispatcher",
        "description": "Dispatch operator"
      },
      {
        "key": "driver",
        "label": "Driver",
        "description": "Vehicle driver"
      }
    ],
    "admin_roles": [],
    "default_actor_type": "fleet_manager",
    "default_roles": []
  },
  "skills": [
    {
      "id": "vehicle-tracker",
      "name": "Vehicle Tracker",
      "role": "orchestrator",
      "description": "Fleet orchestrator — handles vehicle queries directly, routes optimization and safety requests to worker skills.",
      "connectors": [
        "fleet-mcp",
        "handoff-controller-mcp"
      ]
    },
    {
      "id": "route-optimizer",
      "name": "Route Optimizer",
      "role": "worker",
      "description": "Route optimization, trip creation, and multi-stop planning.",
      "connectors": [
        "fleet-mcp"
      ]
    },
    {
      "id": "safety-monitor",
      "name": "Safety Monitor",
      "role": "worker",
      "description": "Driver safety monitoring and scoring.",
      "connectors": [
        "fleet-mcp"
      ]
    }
  ],
  "grants": [
    {
      "key": "fleet.vehicle_id",
      "description": "Access grant for a specific vehicle",
      "issued_by": [
        "vehicle-tracker"
      ],
      "consumed_by": [
        "route-optimizer",
        "safety-monitor"
      ],
      "ttl_seconds": 3600
    },
    {
      "key": "fleet.driver_id",
      "description": "Access grant for a driver profile",
      "issued_by": [
        "vehicle-tracker"
      ],
      "consumed_by": [
        "safety-monitor"
      ],
      "ttl_seconds": 3600
    }
  ],
  "handoffs": [
    {
      "id": "tracker-to-optimizer",
      "from": "vehicle-tracker",
      "to": "route-optimizer",
      "trigger": "Route optimization, trip creation, or route suggestion request",
      "grants_passed": [
        "fleet.vehicle_id"
      ],
      "mechanism": "handoff-controller-mcp"
    },
    {
      "id": "tracker-to-safety",
      "from": "vehicle-tracker",
      "to": "safety-monitor",
      "trigger": "Safety alert check or driver safety score request",
      "grants_passed": [
        "fleet.vehicle_id",
        "fleet.driver_id"
      ],
      "mechanism": "handoff-controller-mcp"
    }
  ],
  "routing": {
    "api": {
      "default_skill": "vehicle-tracker"
    },
    "telegram": {
      "default_skill": "vehicle-tracker"
    }
  },
  "platform_connectors": [
    {
      "id": "handoff-controller-mcp",
      "required": true,
      "description": "Handoff controller for skill-to-skill transfers",
      "used_by": [
        "vehicle-tracker"
      ]
    },
    {
      "id": "fleet-mcp",
      "description": "Fleet data connector — vehicle tracking, routes, safety, and UI dashboard",
      "required": true,
      "ui_capable": true,
      "used_by": [
        "vehicle-tracker",
        "route-optimizer",
        "safety-monitor"
      ]
    }
  ],
  "ui_plugins": [
    {
      "id": "mcp:fleet-mcp:fleet-dashboard",
      "name": "Fleet Dashboard",
      "version": "1.0.0",
      "type": "ui",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/fleet-dashboard/index.html",
        "reactNative": {
          "component": "fleet-dashboard"
        }
      },
      "capabilities": {
        "location": true
      },
      "channels": [
        "command"
      ],
      "commands": [
        {
          "name": "focus_vehicle",
          "description": "Highlight a specific vehicle on the fleet map",
          "input_schema": {
            "type": "object",
            "properties": {
              "vehicle_id": {
                "type": "string"
              }
            },
            "required": [
              "vehicle_id"
            ]
          }
        }
      ]
    }
  ],
  "security_contracts": []
}
