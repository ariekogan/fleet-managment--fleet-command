{
  "id": "route-optimizer",
  "name": "Route Optimizer",
  "description": "Route optimization, trip creation, and multi-stop planning.",
  "version": "2.0.0",
  "phase": "DEPLOYED",
  "problem": {
    "statement": "Dispatchers need optimized routes and trip management for fleet vehicles.",
    "context": "Fleet vehicles operate in the Tel Aviv metropolitan area. This worker skill handles all route and trip operations.",
    "goals": [
      "Calculate optimal routes",
      "Provide route alternatives",
      "Create and manage trip assignments"
    ]
  },
  "role": {
    "name": "Route Optimization Specialist",
    "persona": "You analyze traffic, distance, and vehicle constraints. Suggest best routes with clear ETA estimates. You can also create trip assignments for vehicles. Keep responses concise with key metrics.",
    "goals": [
      "Optimize routes for fleet vehicles",
      "Provide route alternatives with trade-offs",
      "Create trip assignments"
    ],
    "limitations": [
      "Cannot override driver navigation"
    ],
    "communication_style": {
      "tone": "technical",
      "verbosity": "concise"
    }
  },
  "intents": {
    "supported": [
      {
        "id": "optimize_route",
        "description": "Optimize route for a vehicle to a destination",
        "examples": [
          "Optimize route for VH-003 to Jerusalem",
          "Best route to Haifa for VH-001",
          "Fastest route to Beer Sheva"
        ]
      },
      {
        "id": "suggest_routes",
        "description": "Get route suggestions between two points",
        "examples": [
          "Show routes from Herzliya to Ashdod",
          "Compare routes to Beer Sheva",
          "What are my options from Tel Aviv to Haifa?"
        ]
      },
      {
        "id": "create_trip",
        "description": "Create a trip assignment for a vehicle",
        "examples": [
          "Create a trip for VH-001 from Tel Aviv to Haifa",
          "Assign VH-005 to deliver from Ramat Gan to Jerusalem",
          "Schedule a trip for VH-003"
        ]
      }
    ],
    "thresholds": {
      "accept": 0.8,
      "clarify": 0.5,
      "reject": 0.3
    },
    "out_of_domain": {
      "action": "redirect",
      "message": ""
    }
  },
  "engine": {
    "rv2": {
      "max_iterations": 16,
      "iteration_timeout_ms": 30000,
      "allow_parallel_tools": false,
      "on_max_iterations": "ask_user"
    },
    "hlr": {
      "enabled": true,
      "critic": {
        "enabled": true,
        "check_interval": 3,
        "strictness": "medium"
      },
      "reflection": {
        "enabled": true,
        "depth": "shallow"
      },
      "replanning": {
        "enabled": true,
        "max_replans": 5
      }
    },
    "autonomy": {
      "level": "autonomous"
    },
    "finalization_gate": {
      "enabled": true,
      "max_retries": 2
    },
    "internal_error": {
      "enabled": true,
      "tool_not_found": {
        "enter_resolution_after": 1,
        "retryable": false
      },
      "resolution": {
        "max_iterations": 1,
        "allowed_capabilities": [
          "read",
          "search",
          "document_output"
        ]
      },
      "loop_detection": {
        "enabled": true,
        "identical_call_threshold": 2
      }
    },
    "model": "claude-sonnet-4-20250514",
    "temperature": 0.2
  },
  "tools": [
    {
      "id": "tool-route-optimize-2",
      "id_status": "permanent",
      "name": "fleet.route.optimize",
      "description": "Calculate optimal route for a vehicle to a destination.",
      "inputs": [
        {
          "name": "vehicle_id",
          "type": "string",
          "required": true,
          "description": "Vehicle to route"
        },
        {
          "name": "destination",
          "type": "string",
          "required": true,
          "description": "Destination"
        },
        {
          "name": "optimize_for",
          "type": "string",
          "required": false,
          "description": "time, distance, or fuel"
        }
      ],
      "output": {
        "type": "object",
        "description": "Optimized route with distance, time, and fuel estimate"
      },
      "source": {
        "type": "mcp_bridge",
        "connection_id": "fleet-mcp",
        "mcp_tool": "route.optimize"
      },
      "policy": {
        "allowed": "always"
      }
    },
    {
      "id": "tool-route-suggest-2",
      "id_status": "permanent",
      "name": "fleet.route.suggest",
      "description": "Suggest route alternatives between two points with traffic and fuel comparisons.",
      "inputs": [
        {
          "name": "origin",
          "type": "string",
          "required": true,
          "description": "Start point"
        },
        {
          "name": "destination",
          "type": "string",
          "required": true,
          "description": "End point"
        }
      ],
      "output": {
        "type": "object",
        "description": "Array of route alternatives with distance, time, fuel, and traffic"
      },
      "source": {
        "type": "mcp_bridge",
        "connection_id": "fleet-mcp",
        "mcp_tool": "route.suggest"
      },
      "policy": {
        "allowed": "always"
      }
    },
    {
      "id": "tool-trip-create",
      "id_status": "permanent",
      "name": "fleet.trip.create",
      "description": "Create a new trip assignment for a vehicle.",
      "inputs": [
        {
          "name": "vehicle_id",
          "type": "string",
          "required": true,
          "description": "Vehicle to assign"
        },
        {
          "name": "origin",
          "type": "string",
          "required": true,
          "description": "Trip starting location"
        },
        {
          "name": "destination",
          "type": "string",
          "required": true,
          "description": "Trip destination"
        }
      ],
      "output": {
        "type": "object",
        "description": "Created trip with ID, driver, and estimated duration"
      },
      "source": {
        "type": "mcp_bridge",
        "connection_id": "fleet-mcp",
        "mcp_tool": "trip.create"
      },
      "policy": {
        "allowed": "always"
      }
    }
  ],
  "meta_tools": [],
  "triggers": [],
  "connectors": [
    "fleet-mcp"
  ],
  "policy": {
    "guardrails": {
      "never": [],
      "always": []
    },
    "approvals": [],
    "workflows": [],
    "escalation": {
      "enabled": false,
      "conditions": [],
      "target": ""
    }
  },
  "channels": [],
  "access_policy": {
    "rules": [
      {
        "tools": [
          "*"
        ],
        "effect": "allow"
      }
    ]
  }
}
